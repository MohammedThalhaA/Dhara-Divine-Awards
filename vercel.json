{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://dhara-divineawardsadmin.vercel.app/api/:path*"
    },
    {
      "source": "/admin/:path*",
      "destination": "https://dhara-divineawardsadmin.vercel.app/admin/:path*"
    },
    {
      "source": "/_next/:path*",
      "destination": "https://dhara-divineawardsadmin.vercel.app/_next/:path*"
    },
    {
      "source": "/((?!admin|_next|api).*)",
      "destination": "/index.html"
    }
  ]
}
